# =============================================================================
# Biomedical Equipment Troubleshooting Agent - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# APPLICATION MODE
# =============================================================================
# Options: mock, usb
# - mock: Use simulated signals from predefined scenarios (default)
# - usb: Connect to Mastech MS8250D multimeter via USB
APP_MODE=mock

# Mock mode settings
MOCK_SCENARIO=cctv-psu-output-rail

# USB Multimeter settings (for Mastech MS8250D)
# Leave USB_PORT empty for auto-detection
USB_PORT=
USB_BAUD_RATE=2400
USB_TIMEOUT=2.0

# =============================================================================
# LLM Configuration (SELF-HEALING - Multiple Keys/Models)
# =============================================================================
# The system automatically rotates through keys and models on failure
# This provides resilience against rate limits and 503 errors

# Multiple API keys (comma-separated) - system rotates on failure
# GROQ_API_KEY=gsk_xxx1,gsk_xxx2,gsk_xxx3
# OR use single key (backwards compatible)
GROQ_API_KEY=your_groq_api_key_here

# Multiple models (comma-separated) - system falls back to next model
# LLM_MODELS=llama-3.3-70b-versatile,llama-3.1-70b-versatile,mixtral-8x7b-32768
LLM_MODELS=llama-3.3-70b-versatile

# Retry Configuration (optional - defaults shown)
MAX_RETRIES_PER_KEY=2
MAX_RETRIES_PER_MODEL=2
BACKOFF_BASE_SECONDS=1.0
BACKOFF_MAX_SECONDS=16.0

# Legacy (still works for backwards compatibility)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# =============================================================================
# EMBEDDINGS CONFIGURATION (RAG)
# =============================================================================
# Local (RECOMMENDED - FREE, no API key needed)
# Uses sentence-transformers on CPU
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================================================
# CHROMA DB Configuration (Embedded Mode - No Docker Required)
# =============================================================================
# ChromaDB runs in embedded mode automatically
# No docker or server needed - works out of the box
CHROMADB_COLLECTION=biomed_equipment

# =============================================================================
# LANGSMITH OBSERVABILITY (FREE TIER)
# =============================================================================
# Sign up: https://smith.langchain.com
# Tracing helps debug and visualize agent behavior
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=biomed-troubleshooter
LANGCHAIN_TRACING=true

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# IMAGE SERVER CONFIGURATION
# =============================================================================
# Base URL for equipment images
# Dev: http://localhost:8000 (run: python -m http.server 8000 --directory data/equipment)
# Prod: https://images.example.com (or your CDN/Cloudinary URL)
IMAGE_BASE_URL=http://localhost:8000
